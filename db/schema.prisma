// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --------------------------------------

model User {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  name           String?
  email          String   @unique
  hashedPassword String?
  /// USER | CREATOR | ADMIN
  role           String   @default("USER")

  tokens   Token[]
  sessions Session[]

  artists              Artist[]
  artistMemberships    ArtistMember[]
  showsCreated         Show[]             @relation("ShowCreatedBy")
  roleInvitesSent      RoleInvite[]       @relation("RoleInviteCreator")
  roleInvitesFulfilled RoleInvite[]       @relation("RoleInviteNewUser")
  showArtistInvitesSent ShowArtistInvite[]
}

model Session {
  id                 Int       @id @default(autoincrement())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  expiresAt          DateTime?
  handle             String    @unique
  hashedSessionToken String?
  antiCSRFToken      String?
  publicData         String?
  privateData        String?

  user   User? @relation(fields: [userId], references: [id])
  userId Int?
}

model Token {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  hashedToken String
  type        String
  expiresAt   DateTime
  sentTo      String

  user   User @relation(fields: [userId], references: [id])
  userId Int

  @@unique([hashedToken, type])
}

/// Invite for CREATOR or ADMIN before the user account exists (separate from password-reset Token).
model RoleInvite {
  id           Int       @id @default(autoincrement())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  email        String
  /// CREATOR | ADMIN
  intendedRole String
  tokenHash    String    @unique
  expiresAt    DateTime
  consumedAt   DateTime?

  createdBy       User @relation("RoleInviteCreator", fields: [createdByUserId], references: [id])
  createdByUserId Int

  newUser       User? @relation("RoleInviteNewUser", fields: [createdUserId], references: [id])
  createdUserId Int?

  @@index([email])
}

model Location {
  id            Int      @id @default(autoincrement())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  label         String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  region        String?
  postalCode    String?
  country       String?
  googlePlaceId String?

  shows Show[]
}

model Venue {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  name         String
  slug         String   @unique
  addressLine1 String?
  addressLine2 String?
  city         String?
  region       String?
  postalCode   String?
  country      String?

  shows Show[]
}

model Artist {
  id                Int      @id @default(autoincrement())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  slug              String   @unique
  displayName       String?
  profilePictureUrl String?
  /// Map of platform key -> URL, e.g. { "instagram": "https://..." }
  socialLinks       String?

  owner       User           @relation(fields: [ownerUserId], references: [id])
  ownerUserId Int
  members     ArtistMember[]
  showLinks   ShowArtist[]
}

/// Delegated edit access on an artist profile (owner remains on Artist.ownerUserId).
model ArtistMember {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// EDITOR
  role      String

  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   Int

  @@unique([artistId, userId])
}

model Show {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String?
  startsAt  DateTime
  /// External URL for ticket purchase.
  ticketPurchaseUrl String
  addressLine1      String?
  addressLine2      String?
  city              String?
  region            String?
  postalCode        String?
  country           String?

  location   Location? @relation(fields: [locationId], references: [id])
  locationId Int?

  venue   Venue? @relation(fields: [venueId], references: [id])
  venueId Int?

  createdBy       User @relation("ShowCreatedBy", fields: [createdByUserId], references: [id])
  createdByUserId Int

  artistLinks ShowArtist[]
}

model ShowArtist {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// PENDING | ACCEPTED | DECLINED
  participationStatus String   @default("ACCEPTED")
  acceptedAt            DateTime?
  displayOrder          Int      @default(0)
  billingRole           String?

  show   Show   @relation(fields: [showId], references: [id], onDelete: Cascade)
  showId Int

  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId Int

  invite ShowArtistInvite?

  @@unique([showId, artistId])
  @@index([participationStatus])
}

model ShowArtistInvite {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  tokenHash String    @unique
  expiresAt DateTime
  consumedAt DateTime?

  showArtist   ShowArtist @relation(fields: [showArtistId], references: [id], onDelete: Cascade)
  showArtistId Int        @unique

  invitedBy       User @relation(fields: [invitedByUserId], references: [id])
  invitedByUserId Int
}
